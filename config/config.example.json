{
  "server": {
    "host": "0.0.0.0",
    "port": 3000,
    "logLevel": "info",
    "bodyLimitMb": 20
  },
  "fetch": {
    "timeoutMs": 10000,
    "maxBytes": 10485760
  },
  "logging": {
    "fileEnabled": true,
    "directory": "logs",
    "level": "info"
  },
  "auth": {
    "enabled": false,
    "headerName": "x-api-key",
    "apiKeys": [
      "replace-with-your-api-key"
    ]
  },
  "llm": {
    "provider": "deepseek",
    "model": "deepseek-v4-flash",
    "apiKey": "replace-with-your-llm-key",
    "baseUrl": "https://api.deepseek.com",
    "timeoutMs": 30000,
    "logPrompts": true,
    "logResponses": true,
    "logRawPayloads": false,
    "reviewSecrets": true,
    "reviewFindings": true,
    "allowedSecretTypes": [
      "bearer-token",
      "aws-key",
      "jwt"
    ],
    "allowedFindingCategories": [
      "敏感凭据",
      "云配置",
      "JWT/OAuth"
    ]
  }
}
